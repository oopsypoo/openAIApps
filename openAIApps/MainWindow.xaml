<Window x:Class="openAIApps.MainWindow"
        x:Name="openAIApps"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:converters="clr-namespace:openAIApps.Converters"
        xmlns:local="clr-namespace:openAIApps"
        mc:Ignorable="d"
        Title="OpenAiApps" Height="768" Width="1080" Icon="/oai_small.png" >

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />

        <Style x:Key="StatusBarStyle" TargetType="StatusBar">
            <Setter Property="Height" Value="22" />
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="OrangeRed"/>
            <Setter Property="BorderBrush" Value="DarkRed"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
        </Style>

        <Style x:Key="TextBoxRequest" TargetType="TextBox">
            <Setter Property="TabIndex" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="TextBoxResponse" TargetType="TextBox">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="IsEnabled" Value="True" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible" />
        </Style>

        <Style x:Key="SliderGPTOptions" TargetType="Slider">
            <Setter Property="SmallChange" Value="0.1" />
        </Style>
        <Style x:Key="smallText" TargetType="Expander">
            <Setter Property="FontSize" Value="7" />
            <Setter Property="Foreground" Value="DarkGray" />
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontStyle" Value="Normal"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="SendRequest" TargetType="Button">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="TabIndex" Value="2" />
            <Setter Property="Content" Value="Send Request" />
            <Setter Property="Width" Value="120" />
            <Setter Property="Height" Value="20" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Background" Value="LightGreen" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="LimeGreen" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ToolTip" Value="Delete session"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FF0000"/>
                                <Setter Property="Foreground" Value="#D32F2F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33CC0000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Subtle horizontal splitter -->
        <Style x:Key="HorizontalGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Height" Value="5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="#D0D0D0"/>
            <Setter Property="ShowsPreview" Value="True"/>
            <Setter Property="ResizeDirection" Value="Rows"/>
            <Setter Property="ResizeBehavior" Value="PreviousAndNext"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Cursor" Value="SizeNS"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="Transparent">
                            <Border Height="1"
                                VerticalAlignment="Center"
                                Background="#B8B8B8"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C7D7EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Subtle vertical splitter -->
        <Style x:Key="VerticalGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Width" Value="5"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="#D0D0D0"/>
            <Setter Property="ShowsPreview" Value="True"/>
            <Setter Property="ResizeDirection" Value="Columns"/>
            <Setter Property="ResizeBehavior" Value="PreviousAndNext"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Cursor" Value="SizeWE"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="Transparent">
                            <Border Width="1"
                                HorizontalAlignment="Center"
                                Background="#B8B8B8"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C7D7EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid VerticalAlignment="Stretch"
          HorizontalAlignment="Stretch"
          UseLayoutRounding="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Height="18" IsEnabled="True" IsMainMenu="True">
            <MenuItem Header="File" Name="menuFile" Click="menuFile_Click" IsEnabled="True" AllowDrop="True">
                <MenuItem Header="Settings" x:Name="menuSettings" IsEnabled="True" Click="menuSettings_Click"/>
                <MenuItem Header="Exit" Name="menuExit" Click="menuExit_Click" IsEnabled="True" />
            </MenuItem>
            <MenuItem Header="Tools" Name="menuTools" IsEnabled="True" AllowDrop="True">
                <MenuItem Header="Record sound" Name="menuRecord" Click="menuRecord_Click" IsEnabled="True" />
                <MenuItem Header="Convert WAV" Name="menuConvert" Click="menuConvert_Click" IsEnabled="True" />
                <MenuItem Header="Play Sound File" Name="menuPlayFile" Click="menuPlayFile_Click" IsEnabled="True" />
                <MenuItem Header="SpeechSynthesis Options" Name="menuSpeechSynthesisTool" Click="menuSpeechSynthesisTool_Click" IsEnabled="True" />
                <MenuItem Header="Available Models" Name="menuAvlblMdls" Click="menuAvailableModels_Click" IsEnabled="True" />
            </MenuItem>
            <MenuItem Header="Help" Name="menuHelp" Click="menuHelp_Click" IsEnabled="True" AllowDrop="True">
                <MenuItem Header="About" Name="menuAbout" Click="menuAbout_Click" IsEnabled="True"/>
            </MenuItem>
        </Menu>
        <TabControl Grid.Row="1"
                Background="Azure"
                x:Name="tabMain"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                SelectionChanged="tabMain_SelectionChanged">
            <!-- ******************************************** -->
            <!-- Centered around Responses-tab(takes over for -->
            <!-- vision and image-generation) and video-tab.-->
            <!-- Not giving up/removing STT or TTS (whisper) yet-->
            <!-- ******************************************** -->

            <!-- Until i fix/ckean up the code for whisper (STT and TTS, this is just hogwash -->
            <TabItem Header="Whisper"  Name="tpWhisper" TabIndex="3" Visibility="Collapsed">
                <Grid x:Name="gridWhisper" VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="cdWhisperReqRes" Width="185*"/>
                        <ColumnDefinition Width="621*"/>
                        <ColumnDefinition x:Name="cdWhisperOptions" Width="269*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <!-- For now hide it -->
                    <StackPanel Visibility="Collapsed" Grid.Row="0" Grid.Column="0" Grid.RowSpan="5" x:Name="spWhisperInput" Orientation="Vertical" Grid.ColumnSpan="3" Margin="0,0,268,0" >
                        <Label Grid.Row="0" Grid.Column="0">OpenAi response</Label>
                        <TextBox  Grid.Column="0" Style="{StaticResource TextBoxResponse}"  x:Name="txtWhisperPrompt" />
                        <Button  Grid.Column="0" Style="{StaticResource SendRequest}" x:Name="btnWhisperSendRequest" Click="btnWhisperSendRequest_Click"/>
                        <Label Grid.Row="3" Grid.Column="0">OpenAi response</Label>
                        <TextBox  Grid.Column="0" 
                                  Style="{StaticResource TextBoxResponse}"  
                                  x:Name="txtWhisperResponse" />
                    </StackPanel>
                    <!-- For now hide it -->
                    <GroupBox Visibility="Collapsed" x:Name="groupWhisper" Header="Whisper Options" Grid.Row="0" Grid.Column="2" Grid.RowSpan="5">
                        <StackPanel x:Name="spWhisper" Orientation="Vertical" Margin="5">
                            <Label Content="Speach to text" />
                            <ComboBox x:Name="cmbSpeachToText" IsEditable="False" IsReadOnly="True" SelectionChanged="cmbSpeachToText_SelectionChanged">
                                <ComboBoxItem IsSelected="True" Content="Transcription" />
                                <ComboBoxItem Content="Translation" />
                            </ComboBox>
                            <Label Content="Select an Audio File" />
                            <Button x:Name="btnAudioOpenFile" Content="Open Audiofile" Click="btnAudioOpenFile_Click" />
                            <Label x:Name="lblSelectedAudioFile" Content="Selected File" />
                            <Label Content="Select language below" />
                            <ComboBox x:Name="cmbLanguage" SelectionChanged="cmbLanguage_SelectionChanged">
                                <ComboBoxItem IsSelected="True" Content="en - English" />
                                <ComboBoxItem Content="nb - Norwegian" />
                                <ComboBoxItem Content="tl - Tagalog" />
                            </ComboBox>

                        </StackPanel>

                    </GroupBox>

                </Grid>
            </TabItem>
            
            <TabItem Header="Video" Name="tpVideo">
                <Grid x:Name="gridVideo"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="cdVideoReqRes" Width="3*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition x:Name="cdVideoOptions" Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- LEFT SIDE -->
                    <GroupBox x:Name="groupVideoIO"
          Header="Video IO"
          Grid.Row="0"
          Grid.Column="0"
          Margin="0"
          VerticalAlignment="Stretch"
          HorizontalAlignment="Stretch">
                        <Grid Margin="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2*" MinHeight="140"/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="2*" MinHeight="120"/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="*" MinHeight="90"/>
                            </Grid.RowDefinitions>

                            <!-- PROMPT SECTION -->
                            <Grid Grid.Row="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0"
                   Content="Video prompt"
                   Margin="0,0,0,2"/>

                                <TextBox Grid.Row="1"
                     x:Name="txtVideoPrompt"
                     Style="{StaticResource TextBoxRequest}"
                     Text="{Binding VideoState.PromptText, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     TextChanged="txtVideoPrompt_TextChanged"/>

                                <Button Grid.Row="2"
                    x:Name="btnVideoSendRequest"
                    Style="{StaticResource SendRequest}"
                    HorizontalAlignment="Stretch"
                    Click="btnVideoGenerateClick"/>
                            </Grid>

                            <!-- SPLITTER 1 -->
                            <GridSplitter Grid.Row="1"
                      Style="{StaticResource HorizontalGridSplitterStyle}" />

                            <!-- SESSION HISTORY SECTION -->
                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0"
                   Content="Session history"
                   Margin="0,0,0,2"/>

                                <ListBox Grid.Row="1"
                     x:Name="lstVideoSessionTurns"
                     VerticalAlignment="Stretch"
                     ItemsSource="{Binding CurrentVideoMessages, RelativeSource={RelativeSource AncestorType=Window}}"
                     SelectedItem="{Binding VideoState.SelectedSessionTurn, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                     SelectionChanged="lstVideoSessionTurns_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4">
                                                <TextBlock Text="{Binding Role}"
                                       FontWeight="Bold"
                                       Foreground="Gray"
                                       FontSize="10"/>
                                                <TextBlock Text="{Binding Content}"
                                       TextWrapping="Wrap"/>
                                                <TextBlock FontSize="10"
                                       Foreground="DimGray"
                                       TextWrapping="Wrap">
                                <Run Text="Model: "/>
                                <Run Text="{Binding ModelUsed}"/>
                                <Run Text=" | Length: "/>
                                <Run Text="{Binding VideoLength}"/>
                                <Run Text=" | Size: "/>
                                <Run Text="{Binding VideoSize}"/>
                                <Run Text=" | RemoteId: "/>
                                <Run Text="{Binding RemoteId}"/>
                                <Run Text=" | Source: "/>
                                <Run Text="{Binding SourceRemoteId}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>

                            <!-- SPLITTER 2 -->
                            <GridSplitter Grid.Row="3"
                      Style="{StaticResource HorizontalGridSplitterStyle}" />

                            <!-- RESPONSE SECTION -->
                            <Grid Grid.Row="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0"
                   Content="OpenAi response"
                   Margin="0,0,0,2"/>

                                <TextBox Grid.Row="1"
                     x:Name="txtVideoResponse"
                     Style="{StaticResource TextBoxResponse}"
                     Text="{Binding VideoState.ResponseText, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />
                            </Grid>
                        </Grid>
                    </GroupBox>

                    <!-- VERTICAL SPLITTER -->
                    <GridSplitter Grid.Row="0"
                      Grid.Column="1"
                      Style="{StaticResource VerticalGridSplitterStyle}" />

                    <!-- RIGHT SIDE -->
                    <GroupBox x:Name="groupVideo"
                  Header="Video Options"
                  Grid.Row="0"
                  Grid.Column="2"
                  Margin="0"
                  VerticalAlignment="Stretch"
                  HorizontalAlignment="Stretch">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Content="Model" />
                                <ComboBox Grid.Row="1"
                              x:Name="cmbVideoModel"
                              IsEditable="False"
                              IsReadOnly="True"
                              SelectedValuePath="Content"
                              SelectedValue="{Binding VideoState.SelectedModel, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                    <ComboBoxItem IsSelected="True" Content="sora-2" />
                                    <ComboBoxItem Content="sora-2-pro" />
                                </ComboBox>

                                <Label Grid.Row="2" Content="Video Length" Margin="0,5,0,2"/>
                                <ComboBox Grid.Row="3"
                              x:Name="cmbVideoLength"
                              SelectedValuePath="Content"
                              SelectedValue="{Binding VideoState.SelectedLength, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                    <ComboBoxItem IsSelected="True" Content="4" />
                                    <ComboBoxItem Content="8" />
                                    <ComboBoxItem Content="12" />
                                </ComboBox>

                                <Label Grid.Row="4" Content="Video Size" Margin="0,5,0,2"/>
                                <ComboBox Grid.Row="5"
                              x:Name="cmbVideoSize"
                              SelectedValuePath="Content"
                              SelectedValue="{Binding VideoState.SelectedSize, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                    <ComboBoxItem IsSelected="True" Content="720x1280" />
                                    <ComboBoxItem Content="1280x720" />
                                    <ComboBoxItem Content="1024x1792" />
                                    <ComboBoxItem Content="1792x1024" />
                                </ComboBox>

                                <Label Grid.Row="6" Content="Input Reference - select an image" Margin="0,5,0,2"/>
                                <Button Grid.Row="7"
                            x:Name="btnOpenVReference"
                            Content="Choose Image"
                            Padding="5,2"
                            Click="btnOpenVReference_Click"/>

                                <Border Grid.Row="8"
                            Margin="0,6,0,0"
                            Padding="6"
                            BorderBrush="DarkGray"
                            BorderThickness="1"
                            Background="#FFF8F8F8">
                                    <Image x:Name="imgVideo"
                               MaxHeight="250"
                               Stretch="Uniform"
                               Source="/no_pic.png" />
                                </Border>

                                <Button Grid.Row="9"
                            x:Name="btmRemoveImage"
                            Margin="0,6,0,0"
                            Padding="5,2"
                            Content="Remove reference pic"
                            Click="btmRemoveImage_Click" />

                                <Label Grid.Row="10" Content="Video history" Margin="0,5,0,2"/>
                                <ListBox Grid.Row="11"
                             x:Name="lstVideoFiles"
                             MinHeight="120"
                             MaxHeight="220"
                             ItemsSource="{Binding VideoHistory, RelativeSource={RelativeSource AncestorType=Window}}"
                             SelectedItem="{Binding VideoState.SelectedLibraryVideo, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                             SelectionChanged="lstVideoFiles_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Id}" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>

                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="White" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDownloaded}" Value="True">
                                                    <Setter Property="Background" Value="#FFC8FFC8"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                                    <Setter Property="Background" Value="#FFFFC8C8"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDownloaded}" Value="False">
                                                    <Setter Property="Background" Value="#FFFFE0B2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>

                                <StackPanel Grid.Row="12" Margin="0,10,0,0">
                                    <CheckBox x:Name="cbVideoRemix"
                                  Content="Remix selected video"
                                  Margin="0,0,0,8"
                                  IsChecked="{Binding VideoState.IsRemix, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"/>

                                    <Button x:Name="btnDownloadVideo"
                                Margin="0,0,0,2"
                                Padding="5,2"
                                Content="Download Selected Video"
                                Click="btnDownloadVideo_Click"/>

                                    <Button x:Name="btnGetStatus"
                                Margin="0,0,0,2"
                                Padding="5,2"
                                Content="GetVideoStatus"
                                Click="btnGetStatus_Click" />

                                    <Button x:Name="btnPlayVideo"
                                Margin="0,0,0,2"
                                Padding="5,2"
                                Content="Play Selected Video"
                                Click="btnPlayVideo_Click" />

                                    <Button x:Name="btnNewVideSession"
                                Margin="0,0,0,2"
                                Padding="5,2"
                                Background="LightGreen"
                                Content="New Session"
                                Click="btnNewVideSession_Click" />

                                    <Button x:Name="btnDeleteVideo"
                                Padding="5,2"
                                Background="#FFF64343"
                                Content="Delete selected Video"
                                Click="btnDeleteVideo_Click" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="Responses" Name="tpResponses" Height="20" VerticalAlignment="Bottom">
                <Grid x:Name="gridResponses"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="cdResponsesReqRes" Width="3*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition x:Name="cdResponsesOptions" Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- LEFT: IO -->
                    <GroupBox x:Name="groupIO"
                              Header="IO"
                              Grid.Row="0"
                              Grid.Column="0"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch"
                              Margin="0">
                        <Grid Margin="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" MinHeight="150"/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="*" MinHeight="150"/>
                            </Grid.RowDefinitions>

                            <!-- REQUEST SECTION -->
                            <!-- Encapsulate to be able to disable at request(Grid) -->
                            <Grid Grid.Row="0"
                                  IsEnabled="{Binding ResponsesState.AreRequestEditingControlsEnabled, RelativeSource={RelativeSource AncestorType=Window}}">
                                <DockPanel Grid.Row="0" LastChildFill="True">
                                    <!-- Header -->
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Label Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Content="Responses prompt" />

                                        <Button Grid.Column="1"
                                            x:Name="btnResponsesAttachFiles"
                                            Margin="6,0,0,0"
                                            Padding="5,2"
                                            Content="Attach files"
                                            Click="btnResponsesAttachFiles_Click"/>

                                        <Button Grid.Column="2"
                                            x:Name="btnResponsesClearAttachments"
                                            Margin="6,0,0,0"
                                            Padding="5,2"
                                            Content="Clear all"
                                            Click="btnResponsesClearAttachments_Click"/>
                                    </Grid>

                                    <!-- Send button -->
                                    <!-- HorizontalAlignment="Stretch" -->
                                    <!-- Remove the stretch. Even if it looks 
                                    good there are chances that you will hit 
                                    'send' when resizing with gridSplitter -->
                                    <Button DockPanel.Dock="Bottom"
                                    x:Name="btnResponsesSendRequest"
                                    Style="{StaticResource SendRequest}"
                                    Click="btnResponsesSendRequestClick"/>
                                    
                                    <!-- Attachments -->
                                    <Border DockPanel.Dock="Bottom"
                                        x:Name="borderResponsesAttachments"
                                        Margin="0,6,0,0"
                                        Padding="6"
                                        BorderBrush="DarkGray"
                                        BorderThickness="1"
                                        Background="#FFF8F8F8"
                                        Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Text="Attached files"
                                                   FontStyle="Italic"
                                                   Margin="0,0,0,2"/>

                                            <ListBox x:Name="lstResponsesPendingAttachments"
                                                 MaxHeight="120"
                                                 ItemsSource="{Binding PendingResponseAttachments, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 SelectionChanged="lstResponsesPendingAttachments_SelectionChanged">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel Margin="0,2">
                                                            <StackPanel DockPanel.Dock="Right"
                                                        Orientation="Horizontal">
                                                                <Button Content="Open"
                                                                    Margin="6,0,0,0"
                                                                    Padding="8,2"
                                                                    Click="btnResponsesOpenPendingAttachment_Click"/>
                                                                <Button Content="Remove"
                                                                    Margin="6,0,0,0"
                                                                    Padding="8,2"
                                                                    Click="btnResponsesRemovePendingAttachment_Click"/>
                                                            </StackPanel>

                                                            <StackPanel>
                                                                <TextBlock Text="{Binding FileName, Mode=OneWay}"
                                                           FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding MediaType}"
                                                           FontSize="10"
                                                           Foreground="DimGray"/>
                                                            </StackPanel>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </Border>

                                    <!-- Main prompt content -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition x:Name="colResponsesPrompt" Width="*" />
                                            <ColumnDefinition x:Name="colResponsesImage" Width="0" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                             x:Name="txtResponsesPrompt"
                                             Style="{StaticResource TextBoxRequest}"
                                             GotKeyboardFocus="SelectAllTextBox_GotKeyboardFocus"
                                             PreviewMouseLeftButtonDown="SelectAllTextBox_PreviewMouseLeftButtonDown"
                                             Text="{Binding ResponsesState.PromptText, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <Border Grid.Column="1"
                                            x:Name="borderResponsesImage"
                                            Margin="6,0,0,0"
                                            BorderBrush="DarkGray"
                                            BorderThickness="1"
                                            Background="#FFF8F8F8"
                                            Visibility="Collapsed">
                                            <Grid Margin="6">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="120"/>
                                                </Grid.RowDefinitions>

                                                <Label Grid.Row="0"
                                       Content="Image Preview" />

                                                <TextBlock Grid.Row="1"
                                           x:Name="txtResponsesPreviewInfo"
                                           Margin="0,0,0,2"
                                           FontSize="10"
                                           Foreground="DimGray"
                                           HorizontalAlignment="Right"
                                           TextWrapping="NoWrap" />

                                                <Image Grid.Row="2"
                                       x:Name="imgResponsesPreview"
                                       Stretch="Uniform"
                                       MaxHeight="250"
                                       MouseLeftButtonDown="imgResponsesPreview_MouseLeftButtonDown">
                                                    <Image.ContextMenu>
                                                        <ContextMenu x:Name="ctxImagePreview">
                                                            <MenuItem Header="Open" Click="MenuItemImageOpen_Click"/>
                                                            <Separator/>
                                                            <MenuItem Header="Open with" Click="MenuItemImageOpenWith_Click" />
                                                        </ContextMenu>
                                                    </Image.ContextMenu>
                                                </Image>

                                                <TextBlock Grid.Row="3"
                                           Margin="0,8,0,6"
                                           Text="Images in selected turn"
                                           FontStyle="Italic"
                                           Foreground="DimGray" />

                                                <ListBox Grid.Row="4"
                                         x:Name="lstResponsesImages"
                                         ItemsSource="{Binding ResponsePreviewImages, RelativeSource={RelativeSource AncestorType=Window}}"
                                         SelectionChanged="lstResponsesImages_SelectionChanged">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Margin="4,2">
                                                                <TextBlock Text="{Binding FileName, Mode=OneWay}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding MediaType, Mode=OneWay}"
                                                           FontSize="10"
                                                           Foreground="DimGray"
                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DockPanel>
                            </Grid>
                            <!-- HORIZONTAL SPLITTER -->
                            <GridSplitter Grid.Row="1"
                              Style="{StaticResource HorizontalGridSplitterStyle}" />

                            <!-- RESPONSE SECTION -->
                            <DockPanel Grid.Row="2" LastChildFill="True" Margin="0">
                                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,2" LastChildFill="False">
                                    <Label DockPanel.Dock="Left"
                                           Margin="0"
                                           VerticalAlignment="Center"
                                           Content="OpenAi response" />

                                    <Expander x:Name="expResponsesTheme"
                                              DockPanel.Dock="Right"
                                              Style="{StaticResource smallText}"
                                              Header="Highlighting-theme" 
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              ExpandDirection="Down">
                                        <Border Padding="6"
                                                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                                BorderBrush="DarkGray"
                                                BorderThickness="1">
                                            <ComboBox x:Name="cmbResponsesMarkdownTheme"
                                                      Width="180"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectionChanged="cmbResponsesMarkdownTheme_SelectionChanged"/>
                                        </Border>
                                    </Expander>
                                    <Expander x:Name="expResponsePageTheme" 
                                              DockPanel.Dock="Right"
                                              Style="{StaticResource smallText}"
                                              Header="Page-theme" 
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              ExpandDirection="Down">
                                        <Border Padding="6"
                                                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                                BorderBrush="DarkGray"
                                                BorderThickness="1">
                                            <ComboBox x:Name="cmbResponsesPageTheme"
                                                      Width="180"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectionChanged="cmbResponsesPageTheme_SelectionChanged" />
                                        </Border>
                                    </Expander>
                                </DockPanel>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            Margin="0"
                                            BorderBrush="DarkGray"
                                            BorderThickness="1"
                                            Background="White">
                                        <wv2:WebView2 x:Name="wvResponsesResponse"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      DefaultBackgroundColor="White" />
                                    </Border>

                                    <Border Grid.Row="1"
        Margin="0,8,0,0"
        Padding="0"
        Background="#FFFDF7"
        BorderBrush="#E5C76B"
        BorderThickness="1"
        CornerRadius="6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ResponsesState.DeveloperPendingReviewVisible, RelativeSource={RelativeSource AncestorType=Window}}"
                             Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                Background="#D6A400"
                CornerRadius="6,0,0,6" />

                                            <StackPanel Grid.Column="1"
                    Margin="12,10,12,10">
                                                <TextBlock Text="Pending file change review"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Foreground="#6C5200"
                       Margin="0,0,0,6" />

                                                <Border Background="#FFF7D6"
                    BorderBrush="#F0D98A"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8"
                    Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <TextBlock Margin="0,0,0,4">
                        <Run Text="Tool: "
                             FontWeight="SemiBold" />
                        <Run Text="{Binding ResponsesState.DeveloperPendingReviewToolName, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        </TextBlock>

                                                        <TextBlock Text="{Binding ResponsesState.DeveloperPendingReviewTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />

                                                        <TextBlock Text="{Binding ResponsesState.DeveloperPendingReviewSummary, RelativeSource={RelativeSource AncestorType=Window}}"
                               TextWrapping="Wrap"
                               Foreground="#333333" />
                                                    </StackPanel>
                                                </Border>

                                                <TextBlock Text="Review the proposed changes above before approving."
                       Foreground="#7A6A2A"
                       FontStyle="Italic"
                       Margin="0,0,0,10" />

                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Approve changes"
                        Width="140"
                        Height="32"
                        Margin="0,0,8,0"
                        FontWeight="SemiBold"
                        Background="#DFF2E1"
                        BorderBrush="#8FBE95"
                        Click="ApprovePendingToolReview_Click" />

                                                    <Button Content="Reject"
                        Width="100"
                        Height="32"
                        Background="#F6E3E3"
                        BorderBrush="#D2A4A4"
                        Click="RejectPendingToolReview_Click" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DockPanel>
                        </Grid>
                    </GroupBox>

                    <!-- VERTICAL SPLITTER -->
                    <GridSplitter Grid.Row="0"
                      Grid.Column="1"
                      Style="{StaticResource VerticalGridSplitterStyle}" />

                    <!-- RIGHT: OPTIONS -->
                    <GroupBox x:Name="groupResponses"
                              Header="Responses Options"
                              Grid.Row="0"
                              Grid.Column="2"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch"
                              Margin="0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Model -->
                                <Label Grid.Row="0" Content="Model" />
                                <ComboBox Grid.Row="1"
                                          IsEnabled="{Binding ResponsesState.AreRequestEditingControlsEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                          x:Name="cmbResponsesModel"
                                          IsEditable="False"
                                          IsReadOnly="True"
                                          SelectedValuePath="Tag"
                                          SelectedValue="{Binding ResponsesState.SelectedModel, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />

                                <!-- Reasoning -->
                                <Label Grid.Row="2" Content="Reasoning" Margin="0,5,0,2"/>
                                <ComboBox Grid.Row="3"
                                          IsEnabled="{Binding ResponsesState.AreRequestEditingControlsEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                          x:Name="cmbReasoning"
                                          IsEditable="False"
                                          SelectedValuePath="Tag"
                                          SelectedValue="{Binding ResponsesState.SelectedReasoning, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                    <ComboBoxItem Content="none" IsSelected="True" Tag="none"/>
                                    <ComboBoxItem Content="minimal" Tag="minimal"/>
                                    <ComboBoxItem Content="low" Tag="low"/>
                                    <ComboBoxItem Content="medium" Tag="medium"/>
                                    <ComboBoxItem Content="high" Tag="high"/>
                                    <ComboBoxItem Content="xhigh" Tag="xhigh"/>
                                </ComboBox>

                                <!-- Tools -->
                                <Label Grid.Row="4" Content="Available Tools" Margin="0,5,0,2"/>

                                <Grid Grid.Row="5"
                                      IsEnabled="{Binding ResponsesState.AreRequestEditingControlsEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Margin="0,2,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <CheckBox Grid.Row="0"
                                              x:Name="cbToolText"
                                              Content="Text (no tools)"
                                              Margin="0,0,0,2"
                                              IsChecked="{Binding ResponsesState.UseTextTool, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />

                                    <!-- Web search -->
                                    <Border Grid.Row="1"
                                            Margin="0,0,0,8"
                                            Padding="6"
                                            BorderBrush="#DDDDDD"
                                            BorderThickness="1"
                                            Background="#FFF8F8F8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <CheckBox Grid.Row="0"
                                                      x:Name="cbToolWebSearch"
                                                      Content="Web search"
                                                      IsChecked="{Binding ResponsesState.UseWebSearch, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />

                                            <Grid Grid.Row="1"
                                                  Margin="16,6,0,0"
                                                  Visibility="{Binding ResponsesState.IsWebSearchOptionsEnabled,
                                                           RelativeSource={RelativeSource AncestorType=Window},
                                                           Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Label Grid.Row="0" Content="Search Context Size" />
                                                <ComboBox Grid.Row="1"
                                                          x:Name="cmbSearchContextSize"
                                                          SelectedValuePath="Tag"
                                                          SelectedValue="{Binding ResponsesState.SearchContextSize, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                                    <ComboBoxItem Content="low" Tag="low"/>
                                                    <ComboBoxItem Content="medium" Tag="medium"/>
                                                    <ComboBoxItem Content="high" Tag="high"/>
                                                </ComboBox>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <!-- Image generation -->
                                    <Border Grid.Row="2"
                                            Margin="0,0,0,8"
                                            Padding="6"
                                            BorderBrush="#DDDDDD"
                                            BorderThickness="1"
                                            Background="#FFF8F8F8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <CheckBox Grid.Row="0"
                                          x:Name="cbToolImageGeneration"
                                          Content="Image Generation"
                                          Margin="0,0,0,2"
                                          IsChecked="{Binding ResponsesState.UseImageGeneration, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />

                                            <Grid Grid.Row="1"
                                                  Margin="16,6,0,0"
                                                  Visibility="{Binding ResponsesState.IsImageGenerationOptionsVisible,
                                                           RelativeSource={RelativeSource AncestorType=Window},
                                                           Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Label Grid.Row="0" Content="Image Quality" />
                                                <ComboBox Grid.Row="1"
                                                          x:Name="cmbImageGenQuality"
                                                          SelectedValuePath="Tag"
                                                          IsEnabled="{Binding ResponsesState.IsImageGenerationOptionsEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedValue="{Binding ResponsesState.ImageGenQuality, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                                    <ComboBoxItem Content="auto" Tag="auto" IsSelected="True"/>
                                                    <ComboBoxItem Content="low" Tag="low"/>
                                                    <ComboBoxItem Content="medium" Tag="medium"/>
                                                    <ComboBoxItem Content="high" Tag="high"/>
                                                </ComboBox>

                                                <Label Grid.Row="2" Content="Image Size" Margin="0,8,0,4"/>
                                                <ComboBox Grid.Row="3"
                                                          x:Name="cmbImageGenSize"
                                                          SelectedValuePath="Tag"
                                                          IsEnabled="{Binding ResponsesState.IsImageGenerationOptionsEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedValue="{Binding ResponsesState.ImageGenSize, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                                    <ComboBoxItem Content="auto" Tag="auto" IsSelected="True"/>
                                                    <ComboBoxItem Content="1024x1024" Tag="1024x1024"/>
                                                    <ComboBoxItem Content="1536x1024" Tag="1536x1024"/>
                                                    <ComboBoxItem Content="1024x1536" Tag="1024x1536"/>
                                                </ComboBox>

                                                <Label Grid.Row="4"
                                                       Content="Output Format"
                                                       Margin="0,8,0,4"
                                                       ToolTip="jpeg = smaller/faster, png = transparency, webp = compression + transparency"/>
                                                <ComboBox Grid.Row="5"
                                                          x:Name="cmbImageGenOutputFormat"
                                                          SelectedValuePath="Tag"
                                                          IsEnabled="{Binding ResponsesState.IsImageGenerationOptionsEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedValue="{Binding ResponsesState.ImageGenOutputFormat, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                                    <ComboBoxItem Content="jpeg" Tag="jpeg" IsSelected="True"/>
                                                    <ComboBoxItem Content="png" Tag="png"/>
                                                    <ComboBoxItem Content="webp" Tag="webp"/>
                                                </ComboBox>

                                                <Label Grid.Row="6"
                                                       Content="Output Compression"
                                                       Margin="0,8,0,4"
                                                       ToolTip="The compression level (0-100%) for the generated images. This parameter is only supported for the GPT image models with the webp or jpeg output formats, and defaults to 85."/>
                                                <Grid Grid.Row="7"
                                                    IsEnabled="{Binding ResponsesState.IsOutputCompressionEnabled, RelativeSource={RelativeSource AncestorType=Window}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Slider Grid.Column="0"
                                                            Minimum="0"
                                                            Maximum="100"
                                                            TickFrequency="5"
                                                            IsSnapToTickEnabled="True"
                                                            Value="{Binding ResponsesState.ImageGenOutputCompression, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />

                                                    <TextBlock Grid.Column="1"
                                                               Margin="8,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Padding="6,1"
                                                               Background="Aqua"
                                                   Text="{Binding ResponsesState.ImageGenOutputCompression, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                </Grid>

                                                <Label Grid.Row="8"
                                                       Content="Background"
                                                       Margin="0,8,0,4"
                                                       ToolTip="Allows to set transparency for the background of the generated image(s). This parameter is only supported for the GPT image models. Must be one of transparent, opaque or auto."/>
                                                <ComboBox Grid.Row="9"
                                                          x:Name="cmbImageGenBackground"
                                                          SelectedValuePath="Tag"
                                                          SelectedValue="{Binding ResponsesState.ImageGenBackground, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                                    <ComboBoxItem Content="auto" Tag="auto"/>
                                                    <ComboBoxItem Content="opaque" Tag="opaque"/>
                                                    <ComboBoxItem Content="transparent"
                                                      Tag="transparent"
                                                      IsEnabled="{Binding ResponsesState.IsTransparentBackgroundAllowed, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                </ComboBox>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Row="4"
                                            Margin="0,0,0,8"
                                            Padding="6"
                                            BorderBrush="#DDDDDD"
                                            BorderThickness="1"
                                            Background="#FFF8F8F8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <CheckBox Grid.Row="0"
                                                      x:Name="cbToolDeveloperTools"
                                                      Content="Developer Tools"
                                                      IsChecked="{Binding ResponsesState.UseDeveloperTools, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />

                                            <Grid Grid.Row="1"
                                                  Margin="16,6,0,0"
                                                  Visibility="{Binding ResponsesState.IsDeveloperToolsOptionsVisible,
                                                                       RelativeSource={RelativeSource AncestorType=Window},
                                                                       Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Label Grid.Row="0" Content="Repository root" />
                                                <DockPanel Grid.Row="1" LastChildFill="True">
                                                    <Button Content="Browse"
                                                            Width="70"
                                                            Margin="0,0,6,0"
                                                            Click="btnDeveloperBrowseRoot_Click"/>
                                                    <TextBox Text="{Binding ResponsesState.DeveloperRepositoryRoot, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DockPanel>

                                                <Label Grid.Row="2" Content="Scope" Margin="0,8,0,2"/>
                                                <ComboBox Grid.Row="3"
                                                          SelectedValuePath="Tag"
                                                          SelectedValue="{Binding ResponsesState.DeveloperScope, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                                    <ComboBoxItem Content="Current repository only" Tag="repository"/>
                                                    <ComboBoxItem Content="Workspace" Tag="workspace"/>
                                                    <ComboBoxItem Content="Custom" Tag="custom"/>
                                                </ComboBox>

                                                <TextBlock Grid.Row="4"
                                                           Margin="0,8,0,4"
                                                           FontWeight="SemiBold"
                                                           Text="Available functions" />
                                                <StackPanel Grid.Row="5">
                                                    <CheckBox Content="Search project text"
                                                              IsChecked="{Binding ResponsesState.DeveloperToolSearchProjectText, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"/>
                                                    <CheckBox Content="Read project file"
                                                              IsChecked="{Binding ResponsesState.DeveloperToolReadProjectFile, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"/>
                                                    <CheckBox Content="List project files"
                                                              IsChecked="{Binding ResponsesState.DeveloperToolListProjectFiles, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"/>
                                                    <CheckBox Content="Run diagnostics"
                                                              IsChecked="{Binding ResponsesState.DeveloperToolRunDiagnostics, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"/>

                                                    <CheckBox Content="Write project file"
                                                              IsChecked="{Binding ResponsesState.DeveloperToolWriteProjectFile, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                                              IsEnabled="{Binding ResponsesState.DeveloperAllowReadOnlyOnly, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"/>

                                                    <CheckBox Content="Replace in project file"
                                                              IsChecked="{Binding ResponsesState.DeveloperToolReplaceInProjectFile, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                                              IsEnabled="{Binding ResponsesState.DeveloperAllowReadOnlyOnly, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanConverter}}"/>
                                                </StackPanel>

                                                <TextBlock Grid.Row="6"
                                                           Margin="0,8,0,4"
                                                           FontWeight="SemiBold"
                                                           Text="Advanced options" />
                                                <StackPanel Grid.Row="7">
                                                    <CheckBox Content="Allow read-only only"
                                                              IsChecked="{Binding ResponsesState.DeveloperAllowReadOnlyOnly, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />
                                                    <CheckBox Content="Require confirmation before local calls"
                                                              IsChecked="{Binding ResponsesState.DeveloperRequireConfirmation, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />
                                                    <CheckBox Content="Show tool call logs"
                                                              IsChecked="{Binding ResponsesState.DeveloperShowToolLogs, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <CheckBox Grid.Row="3"
                                              x:Name="cbToolComputerUse"
                                              Visibility="Collapsed"
                                              Content="Computer use (preview)"
                                              IsChecked="{Binding ResponsesState.UseComputerUse, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />
                                </Grid>

                                <!-- Actions -->
                                <Button Grid.Row="6"
                                        x:Name="btnResponsesNewChat"
                                        IsEnabled="{Binding ResponsesState.AreRequestEditingControlsEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Margin="0,8,0,0"
                                        Padding="5,2"
                                        Content="New Conversation"
                                        Click="btnResponsesNewChat_Click"/>

                                <ListBox Grid.Row="7"
                                         x:Name="lstResponsesTurns"
                                         IsEnabled="{Binding ResponsesState.AreRequestEditingControlsEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                         Height="150"
                                         Margin="0,8,0,0"
                                         ItemsSource="{Binding CurrentChatMessages, RelativeSource={RelativeSource AncestorType=Window}}"
                                         SelectedItem="{Binding ResponsesState.SelectedTurn, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                         SelectionChanged="lstResponsesTurns_SelectionChanged"
                                         MouseDoubleClick="lstResponsesTurns_MouseDoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="5">
                                                <TextBlock Text="{Binding Role}"
                                                           FontWeight="Bold"
                                                           Foreground="Gray"
                                                           FontSize="10"/>

                                                <TextBlock Text="{Binding Content}"
                                                           TextWrapping="Wrap"/>

                                                <ItemsControl ItemsSource="{Binding MediaFiles}" Margin="0,4,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock FontSize="10"
                                                                       Foreground="SlateGray"
                                                                       TextWrapping="Wrap">
                                                                <Run Text="📎 "/>
                                                                <Run Text="{Binding FileName, Mode=OneWay}"/>
                                                                <Run Text="  "/>
                                                                <Run Text="{Binding MediaType}"/>
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock FontSize="10"
                                                           Foreground="DimGray"
                                                           TextWrapping="Wrap">
                                                    <Run Text="Model: "/>
                                                    <Run Text="{Binding ModelUsed}"/>
                                                    <Run Text=" | Reasoning: "/>
                                                    <Run Text="{Binding ReasoningLevel}"/>
                                                    <Run Text=" | Tools: "/>
                                                    <Run Text="{Binding ActiveTools}"/>
                                                </TextBlock>

                                                <TextBlock FontSize="10"
                                                           Foreground="SlateGray"
                                                           TextWrapping="Wrap"
                                               Text="{Binding ImageToolSummary, Mode=OneWay}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Button Grid.Row="8"
                                        x:Name="btnResponsesDeleteChat"
                                        IsEnabled="{Binding ResponsesState.AreRequestEditingControlsEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Margin="0,8,0,0"
                                        Padding="5,2"
                                        Content="Remove Current Turn"
                                        Click="btnResponsesDeleteChat_Click"/>
                                <Expander Grid.Row="9"
                                          Margin="0,8,0,0"
                                          Header="Local Tool Call Logs"
                                          Visibility="{Binding ResponsesState.UseDeveloperTools,
                                                        RelativeSource={RelativeSource AncestorType=Window},
                                                        Converter={StaticResource BoolToVisibilityConverter}}"
                                          IsExpanded="False">
                                    <Border Margin="0,6,0,0"
                                            Padding="6"
                                            BorderBrush="#DDDDDD"
                                            BorderThickness="1"
                                            Background="#FFF8F8F8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Margin="0,0,0,6"
                                                       FontStyle="Italic"
                                                       Foreground="DimGray"
                                                       Text="Shows local developer tool calls for the current session." />

                                            <ListBox Grid.Row="1"
                                                     MaxHeight="180"
                                                     ItemsSource="{Binding DeveloperToolCallLogs, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,6"
                                                                Padding="6"
                                                                BorderBrush="#E0E0E0"
                                                                BorderThickness="1"
                                                                Background="White">
                                                            <StackPanel>
                                                                <TextBlock FontWeight="SemiBold"
                                                                           Text="{Binding ToolName, Mode=OneWay}" />

                                                                <TextBlock Margin="0,2,0,0"
                                                                           FontSize="11"
                                                                           Foreground="DimGray"
                                                                           Text="{Binding TimestampText, Mode=OneWay}" />

                                                                <TextBlock Margin="0,4,0,0"
                                                                           FontSize="11"
                                                                           Foreground="DarkSlateBlue"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding ResultSummary, Mode=OneWay}" />

                                                                <TextBlock Margin="0,4,0,0"
                                                                           FontSize="11"
                                                                           Foreground="DimGray"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding ArgumentsJson, Mode=OneWay}" />

                                                                <TextBlock Margin="0,4,0,0"
                       FontSize="11"
                       Foreground="SlateGray"
                       TextWrapping="Wrap"
                       Text="{Binding ResultJson, Mode=OneWay}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>
                                </Expander>
                            </Grid>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="Logs" x:Name="tabLogs">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="10,5">
                        <TextBlock Text="Filter by Type: "
                                   VerticalAlignment="Center"
                                   Margin="0,0,5,0"/>

                        <ComboBox x:Name="cbLogTypeFilter"
                                  Width="120"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding LogsState.TypeFilter, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                            <ComboBoxItem Content="All" Tag="All"/>
                            <ComboBoxItem Content="Responses" Tag="Responses"/>
                            <ComboBoxItem Content="Video" Tag="Video"/>
                        </ComboBox>

                        <Label Content="Search Logs:"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>

                        <TextBox x:Name="txtLogSearch"
                                 Width="300"
                                 Margin="10,0"
                                 Text="{Binding LogsState.SearchText, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <Menu Margin="10,0,0,0"
                              VerticalAlignment="Center">
                            <MenuItem Header="Columns">
                                <MenuItem Header="Turns"
                                          IsCheckable="True"
                                          IsChecked="{Binding LogsState.ShowTurns, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />
                                <MenuItem Header="Media"
                                          IsCheckable="True"
                                          IsChecked="{Binding LogsState.ShowMedia, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />
                                <MenuItem Header="Tools"
                                          IsCheckable="True"
                                          IsChecked="{Binding LogsState.ShowTools, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />
                                <MenuItem Header="Model"
                                          IsCheckable="True"
                                          IsChecked="{Binding LogsState.ShowModel, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />
                                <MenuItem Header="Dev"
                                          IsCheckable="True"
                                          IsChecked="{Binding LogsState.ShowDev, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />
                            </MenuItem>
                        </Menu>

                        <Menu Margin="10,0,0,0"
                              VerticalAlignment="Center">
                            <MenuItem Header="Export">
                                <MenuItem Header="Markdown (.md)"
                                          Click="OnExportLogMarkdownClick"/>
                                <MenuItem Header="Text (.txt)"
                                          Click="OnExportLogTextClick"/>
                                <MenuItem Header="HTML (.html)"
                                          Click="OnExportLogHtmlClick"/>
                            </MenuItem>
                        </Menu>
                    </StackPanel>

                    <DataGrid x:Name="dgUnifiedLogs"
                              ItemsSource="{Binding LogView, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding LogsState.SelectedLogRow, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              IsSynchronizedWithCurrentItem="True"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              MouseDoubleClick="OnLogEntryDoubleClick">

                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#0078D7"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#0078D7"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
                        </DataGrid.Resources>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#0078D7"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date"
                                                Binding="{Binding LastUsedAt, StringFormat={}{0:dd.MM HH:mm}}"
                                                Width="110"/>

                            <DataGridTextColumn Header="Type"
                                                Binding="{Binding Endpoint}"
                                                Width="90"/>

                            <DataGridTextColumn x:Name="colLogTurns"
                                                Header="Turns"
                                                Binding="{Binding Turns}"
                                                Width="65"/>

                            <DataGridTextColumn x:Name="colLogMedia"
                                                Header="Media"
                                                Binding="{Binding Media}"
                                                Width="100"/>

                            <DataGridTextColumn x:Name="colLogTools"
                                                Header="Tools"
                                                Binding="{Binding Tools}"
                                                Width="160"/>
                            <DataGridTextColumn x:Name="colLogDev"
                                                Header="Dev"
                                                Binding="{Binding Dev}"
                                                Width="55"/>

                            <DataGridTextColumn x:Name="colLogModel"
                                                Header="Model"
                                                Binding="{Binding Model}"
                                                Width="140"/>

                            <DataGridTextColumn Header="Title"
                                                Binding="{Binding Title}"
                                                Width="*"/>

                            <DataGridTemplateColumn Width="50" Header="Del" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑"
                                                Width="28"
                                                Height="28"
                                                FontSize="15"
                                                Style="{StaticResource DeleteButtonStyle}"
                                                Click="OnDeleteSessionClick"
                                                ClickMode="Press"
                                                CommandParameter="{Binding}"
                                                ToolTip="{Binding Title, StringFormat=Delete {0}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
        <StatusBar Grid.Row="2" Style="{StaticResource StatusBarStyle}">
            <StatusBarItem Padding="4,0">
                <TextBlock x:Name="StatusText"
                       Text="Ready"
                       VerticalAlignment="Center" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
